<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/md_background" />
        </shape>
    </item>
    <item android:gravity="top|start">
        <shape android:shape="oval">
            <solid android:color="#221A237E" />
            <size android:width="400dp" android:height="400dp" />
        </shape>
    </item>
    <item android:gravity="bottom|end">
        <shape android:shape="oval">
            <solid android:color="#220D2187" />
            <size android:width="400dp" android:height="400dp" />
        </shape>
    </item>
</layer-list>
