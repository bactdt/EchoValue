<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top app bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/md_surface"
            android:elevation="0dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/top_bar_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shield"
                app:tint="@color/md_primary" />

            <TextView
                android:id="@+id/top_bar_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/login_title"
                android:textColor="@color/md_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/search_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_search"
                android:visibility="visible"
                app:tint="@color/md_on_surface_variant" />

            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_avatar_circle">

                <TextView
                    android:id="@+id/avatar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="JS"
                    android:textColor="@color/md_on_primary_container"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <!-- Fragment content -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom nav -->
        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/md_surface_container_low"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/nav_vault"
                style="@style/BottomNavItem"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/nav_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/md_on_surface_variant" />

                <TextView
                    android:id="@+id/nav_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/nav_vault"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_generator"
                style="@style/BottomNavItem"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/nav_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_password"
                    app:tint="@color/md_on_surface_variant" />

                <TextView
                    android:id="@+id/nav_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/nav_generator"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_security"
                style="@style/BottomNavItem"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/nav_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_verified_user"
                    app:tint="@color/md_on_surface_variant" />

                <TextView
                    android:id="@+id/nav_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/nav_security"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_settings"
                style="@style/BottomNavItem"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/nav_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/md_on_surface_variant" />

                <TextView
                    android:id="@+id/nav_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/nav_settings"
                    android:textColor="@color/md_on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FAB -->
    <FrameLayout
        android:id="@+id/fab_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="104dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/fab"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_fab"
            android:elevation="6dp"
            android:src="@drawable/ic_add"
            android:stateListAnimator="@null"
            app:tint="@color/md_on_primary" />
    </FrameLayout>
</FrameLayout>