<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_unlock_gradient"
    tools:context=".UnlockActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="96dp"
        android:paddingBottom="32dp">

        <!-- Shield branding -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_shield_circle"
            android:elevation="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_shield"
                app:tint="@color/md_on_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/unlock_title"
            android:textColor="@color/md_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prompt_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/unlock_prompt"
            android:textColor="@color/md_on_surface_variant"
            android:textSize="14sp" />

        <!-- PIN dots -->
        <LinearLayout
            android:id="@+id/pin_dots_container"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/dot_1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />

            <View
                android:id="@+id/dot_2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />

            <View
                android:id="@+id/dot_3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />

            <View
                android:id="@+id/dot_4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />

            <View
                android:id="@+id/dot_5"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />

            <View
                android:id="@+id/dot_6"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_pin_dot" />
        </LinearLayout>

        <!-- Keypad -->
        <GridLayout
            android:id="@+id/keypad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:columnCount="3"
            android:rowCount="4"
            android:useDefaultMargins="false">

            <Button
                android:id="@+id/key_1"
                style="@style/KeypadButton"
                android:text="1" />

            <Button
                android:id="@+id/key_2"
                style="@style/KeypadButton"
                android:text="2" />

            <Button
                android:id="@+id/key_3"
                style="@style/KeypadButton"
                android:text="3" />

            <Button
                android:id="@+id/key_4"
                style="@style/KeypadButton"
                android:text="4" />

            <Button
                android:id="@+id/key_5"
                style="@style/KeypadButton"
                android:text="5" />

            <Button
                android:id="@+id/key_6"
                style="@style/KeypadButton"
                android:text="6" />

            <Button
                android:id="@+id/key_7"
                style="@style/KeypadButton"
                android:text="7" />

            <Button
                android:id="@+id/key_8"
                style="@style/KeypadButton"
                android:text="8" />

            <Button
                android:id="@+id/key_9"
                style="@style/KeypadButton"
                android:text="9" />

            <ImageButton
                android:id="@+id/key_biometric"
                style="@style/KeypadButtonIcon"
                android:src="@drawable/ic_fingerprint" />

            <Button
                android:id="@+id/key_0"
                style="@style/KeypadButton"
                android:text="0" />

            <ImageButton
                android:id="@+id/key_backspace"
                style="@style/KeypadButtonIcon"
                android:src="@drawable/ic_backspace" />
        </GridLayout>

        <!-- Biometric button -->
        <Button
            android:id="@+id/biometric_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_btn_pill_primary"
            android:drawableStart="@drawable/ic_face"
            android:drawableTint="@color/md_on_primary"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:stateListAnimator="@null"
            android:text="@string/unlock_biometric"
            android:textAllCaps="false"
            android:textColor="@color/md_on_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Forgot link -->
        <TextView
            android:id="@+id/forgot_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:text="@string/unlock_forgot"
            android:textColor="@color/md_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
