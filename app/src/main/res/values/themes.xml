<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. Material 3 with Sentry Core palette. -->
    <style name="Base.Theme.Keshe" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary palette -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <!-- Secondary palette -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <!-- Tertiary palette -->
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md_on_tertiary_container</item>

        <!-- Error palette -->
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>
        <item name="colorErrorContainer">@color/md_error_container</item>
        <item name="colorOnErrorContainer">@color/md_on_error_container</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_on_background</item>
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="colorOutline">@color/md_outline</item>
        <item name="colorOutlineVariant">@color/md_outline_variant</item>

        <!-- Status / bars -->
        <item name="android:statusBarColor">@color/md_background</item>
        <item name="android:navigationBarColor">@color/md_surface_container_low</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Keshe" parent="Base.Theme.Keshe" />

    <!-- Typography styles (Roboto Flex weights per design) -->
    <style name="TextAppearance.Keshe.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>
    <style name="TextAppearance.Keshe.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
    </style>
    <style name="TextAppearance.Keshe.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>
    <style name="TextAppearance.Keshe.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>
    <style name="TextAppearance.Keshe.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>
    <style name="TextAppearance.Keshe.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>
    <style name="TextAppearance.Keshe.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_on_surface_variant</item>
    </style>
    <style name="TextAppearance.Keshe.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
    </style>
    <style name="TextAppearance.Keshe.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Reusable widget styles -->
    <style name="Widget.Keshe.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/md_primary</item>
        <item name="android:textColor">@color/md_on_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.Keshe.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/md_outline</item>
        <item name="android:textColor">@color/md_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Keshe.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_primary</item>
        <item name="boxBackgroundColor">@color/md_surface_container_low</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="hintTextColor">@color/md_on_surface_variant</item>
        <item name="android:textColorHint">@color/md_on_surface_variant</item>
    </style>

    <style name="Widget.Keshe.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/md_surface_container_high</item>
        <item name="android:textColor">@color/md_on_surface_variant</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Keypad buttons (number pad for unlock screen) -->
    <style name="KeypadButton">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:background">@drawable/bg_keypad_button</item>
        <item name="android:textColor">@color/md_on_surface</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
    </style>

    <style name="KeypadButtonIcon">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">12dp</item>
        <item name="android:background">@drawable/bg_keypad_button</item>
        <item name="android:scaleType">center</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Filter chips (homepage) -->
    <style name="FilterChipActive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip_active</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textColor">@color/md_on_secondary_container</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FilterChipInactive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_chip_inactive</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textColor">@color/md_on_surface_variant</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Bottom nav items -->
    <style name="BottomNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="BottomNavItemActive">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_chip_active</item>
        <item name="android:layout_marginHorizontal">32dp</item>
        <item name="android:layout_marginVertical">12dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
</resources>
